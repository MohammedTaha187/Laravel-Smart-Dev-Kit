<?php

namespace {{Namespace}};

use App\Http\Controllers\Controller;
use {{ServiceContractPath}}\{{ModelClass}}ServiceInterface;
use {{ModelPath}};
{{StoreRequestImport}}
{{UpdateRequestImport}}
{{ResourceImport}}
{{CollectionImport}}
{{DataImport}}
use Illuminate\Http\JsonResponse;

/**
 * @group {{ModelClass}} Management
 *
 * APIs for managing {{ModelClass}}s
 */
class {{Class}} extends Controller
{
    public function __construct(
        private readonly {{ModelClass}}ServiceInterface $service
    ) {}

    /**
     * Display a listing of the resource.
     */
    public function index(): JsonResponse
    {
        $items = $this->service->getAll();

        return $this->successResponse(
            {{CollectionClass}}::make($items),
            '{{ModelClass}} list retrieved.'
        );
    }

    /**
     * Store a newly created resource in storage.
     */
    public function store({{StoreRequestClass}} $request): JsonResponse
    {
        ${{ModelVariable}} = $this->service->create({{ModelClass}}Data::from($request->validated()));

        return $this->successResponse(
            new {{ResourceClass}}(${{ModelVariable}}),
            '{{ModelClass}} created successfully.',
            201
        );
    }

    /**
     * Display the specified resource.
     */
    public function show({{ModelClass}} ${{ModelVariable}}): JsonResponse
    {
        return $this->successResponse(
            new {{ResourceClass}}(${{ModelVariable}}),
            '{{ModelClass}} retrieved.'
        );
    }

    /**
     * Update the specified resource in storage.
     */
    public function update({{UpdateRequestClass}} $request, {{ModelClass}} ${{ModelVariable}}): JsonResponse
    {
        $this->service->update(${{ModelVariable}}->id, {{ModelClass}}Data::from($request->validated()));

        return $this->successResponse(
            new {{ResourceClass}}(${{ModelVariable}}->fresh()),
            '{{ModelClass}} updated successfully.'
        );
    }

    /**
     * Remove the specified resource from storage.
     */
    public function destroy({{ModelClass}} ${{ModelVariable}}): JsonResponse
    {
        $this->service->delete(${{ModelVariable}}->id);

        return $this->successResponse(null, '{{ModelClass}} deleted successfully.', 204);
    }
}
