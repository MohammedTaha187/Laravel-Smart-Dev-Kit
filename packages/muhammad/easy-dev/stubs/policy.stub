<?php

namespace {{Namespace}};

use {{ModelPath}};
use {{UserPath}};
use Illuminate\Auth\Access\HandlesAuthorization;

class {{Class}}
{
    use HandlesAuthorization;

    /**
     * Determine whether the user can view any models.
     */
    public function viewAny({{UserClass}} $user): bool
    {
        return $user->hasPermissionTo('view-any-{{modelVariable}}');
    }

    /**
     * Determine whether the user can view the model.
     */
    public function view({{UserClass}} $user, {{ModelClass}} ${{ModelVariable}}): bool
    {
        return $user->hasPermissionTo('view-{{modelVariable}}');
    }

    /**
     * Determine whether the user can create models.
     */
    public function create({{UserClass}} $user): bool
    {
        return $user->hasPermissionTo('create-{{modelVariable}}');
    }

    /**
     * Determine whether the user can update the model.
     */
    public function update({{UserClass}} $user, {{ModelClass}} ${{ModelVariable}}): bool
    {
        return $user->hasPermissionTo('update-{{modelVariable}}');
    }

    /**
     * Determine whether the user can delete the model.
     */
    public function delete({{UserClass}} $user, {{ModelClass}} ${{ModelVariable}}): bool
    {
        return $user->hasPermissionTo('delete-{{modelVariable}}');
    }

    /**
     * Determine whether the user can restore the model.
     */
    public function restore({{UserClass}} $user, {{ModelClass}} ${{ModelVariable}}): bool
    {
        return $user->hasPermissionTo('restore-{{modelVariable}}');
    }

    /**
     * Determine whether the user can permanently delete the model.
     */
    public function forceDelete({{UserClass}} $user, {{ModelClass}} ${{ModelVariable}}): bool
    {
        return $user->hasPermissionTo('force-delete-{{modelVariable}}');
    }
}
