<?php

namespace {{Namespace}};

use {{Namespace}}\Contracts\{{ModelClass}}ServiceInterface;
use {{RepositoryContractPath}}\{{RepositoryInterface}};
use {{ModelPath}};
use {{DataPath}};
use Illuminate\Database\Eloquent\Collection;

class {{Class}} implements {{ModelClass}}ServiceInterface
{
    public function __construct(
        private readonly {{RepositoryInterface}} $repo
    ) {}

    public function getAll(): Collection
    {
        return $this->repo->all();
    }

    public function getById(int $id): ?{{ModelClass}}
    {
        return $this->repo->find($id);
    }

    public function create({{ModelClass}}Data $data): {{ModelClass}}
    {
        return $this->repo->create($data->toArray());
    }

    public function update(int $id, {{ModelClass}}Data $data): bool
    {
        return $this->repo->update($id, $data->toArray());
    }

    public function delete(int $id): bool
    {
        return $this->repo->delete($id);
    }
}
