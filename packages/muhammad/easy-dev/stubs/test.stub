<?php

use {{ModelPath}};
use App\Models\User;
use function Pest\Laravel\{getJson, postJson, putJson, patchJson, deleteJson, actingAs};

beforeEach(function () {
    $this->admin = User::factory()->create()->assignRole('admin');
    $this->{{ModelVariable}} = {{ModelClass}}::factory()->create();
});

it('can list all {{ModelVariables}}', function () {
    actingAs($this->admin)
        ->getJson('/api/v1/{{Route}}')
        ->assertOk()
        ->assertJsonPath('success', true)
        ->assertJsonStructure(['data', 'meta', 'message']);
});

it('can create a {{ModelVariable}}', function () {
    $payload = {{ModelClass}}::factory()->make()->toArray();

    actingAs($this->admin)
        ->postJson('/api/v1/{{Route}}', $payload)
        ->assertCreated()
        ->assertJsonPath('success', true)
        ->assertJsonStructure(['data' => ['id']]);
});

it('can show a {{ModelVariable}}', function () {
    actingAs($this->admin)
        ->getJson("/api/v1/{{Route}}/{$this->{{ModelVariable}}->id}")
        ->assertOk()
        ->assertJsonPath('success', true)
        ->assertJsonPath('data.id', $this->{{ModelVariable}}->id);
});

it('can update a {{ModelVariable}}', function () {
    $payload = {{ModelClass}}::factory()->make()->toArray();

    actingAs($this->admin)
        ->putJson("/api/v1/{{Route}}/{$this->{{ModelVariable}}->id}", $payload)
        ->assertOk()
        ->assertJsonPath('success', true);
});

it('can delete a {{ModelVariable}}', function () {
    actingAs($this->admin)
        ->deleteJson("/api/v1/{{Route}}/{$this->{{ModelVariable}}->id}")
        ->assertNoContent();

    $this->assertDatabaseMissing('{{Table}}', ['id' => $this->{{ModelVariable}}->id]);
});
