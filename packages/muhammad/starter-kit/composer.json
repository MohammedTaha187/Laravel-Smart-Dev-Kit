{
    "name": "muhammad/starter-kit",
    "description": "A professional Laravel Starter Kit package for rapid API development with Clean Architecture.",
    "version": "1.0.0",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Muhammad",
            "email": "muhammad@example.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Muhammad\\StarterKit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Muhammad\\StarterKit\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Muhammad\\StarterKit\\StarterKitServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
